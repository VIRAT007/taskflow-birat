# Copy to `.env` in this folder for `docker compose up` variable substitution.
# See also `backend/.env.example` for local (non-Docker) backend development.

# Override the compose default (must stay >= 16 characters for the backend env schema).
JWT_SECRET=replace-with-at-least-16-characters
RUN_SEED=false
BACKEND_PORT=3000
LOG_LEVEL=info
