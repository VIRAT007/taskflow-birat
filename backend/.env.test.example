# Copy to `.env.test` in this folder.
# Prefer a dedicated database or at least a dedicated Postgres `schema` (see `?schema=...`) so
# `npm run test:integration` does not truncate your development data.
NODE_ENV=test
PORT=3000
LOG_LEVEL=error
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow_test?schema=public"
JWT_SECRET="integration-test-jwt-secret-32"

# Global setup runs `prisma db push` against this URL so the test DB matches prisma/schema.prisma.
